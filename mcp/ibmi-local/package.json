{
  "name": "ibmi-local-mcp",
  "version": "0.5.0",
  "description": "Servidor MCP local para agente senior IBM i en VS Code y GitHub Copilot.",
  "type": "module",
  "private": true,
  "bin": {
    "ibmi-local-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "validate:customizations": "node ../../scripts/validate-customizations.mjs",
    "validate:privacy": "node ../../scripts/validate-public-content.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsonc-parser": "^3.3.1",
    "odbc": "^2.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
